---
import Layout from '../../layouts/Layout.astro';
import { languages } from '../../i18n/ui';
import { de } from '../../i18n/de';
import { en } from '../../i18n/en';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const content = lang === 'en' ? en : de;
const t = content.privacy;
---

<Layout title={t.title} lang={lang}>
  <section class="legal-page">
    <div class="container">
      <h1>{t.pageTitle}</h1>
      
      <div class="warning-box">
        <h2>{t.placeholder.heading}</h2>
        <p>{t.placeholder.text}</p>
      </div>
      
      {t.placeholder.topics.map(topic => (
        <div class="privacy-section">
          <h2>{topic.title}</h2>
          <p>{topic.content}</p>
        </div>
      ))}

    </div>
  </section>
</Layout>

<style>
  .legal-page {
    padding: 4rem 0;
    min-height: 60vh;
  }
  .legal-page h1 {
    margin-bottom: 2rem;
    color: var(--primary-color);
  }
  .warning-box {
    background-color: #fffbe6;
    border: 1px solid #fde047;
    color: #713f12;
    padding: 1.5rem;
    border-radius: 0.5rem;
    margin-bottom: 3rem;
  }
  .warning-box h2 {
    margin-top: 0;
  }
  .privacy-section {
    margin-bottom: 2rem;
  }
  .privacy-section h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }
  .privacy-section p {
    line-height: 1.8;
    margin-bottom: 1rem;
  }
</style>
