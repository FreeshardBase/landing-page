---
import Layout from '../../layouts/Layout.astro';
import { languages } from '../../i18n/ui';
import { de } from '../../i18n/de';
import { en } from '../../i18n/en';
import agbDE from '../../content/agb-de.html?raw';
import agbEN from '../../content/agb-en.html?raw';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const content = lang === 'en' ? en : de;
---

<Layout title={content.terms.title} lang={lang}>
  <section class="legal-page">
    <div class="container">
      <div class="terms-content" set:html={lang === 'de' ? agbDE : agbEN} />
    </div>
  </section>
</Layout>

<style>
  .legal-page {
    padding: 4rem 0;
    min-height: 60vh;
  }

  .terms-content :global(h1) {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 2rem;
    color: var(--primary-color);
  }

  .terms-content :global(h2) {
    font-size: 1.4rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    text-align: left;
  }

  .terms-content :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .terms-content :global(p) {
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  .terms-content :global(ul) {
    margin: 0.75rem 0 1rem 1.5rem;
    line-height: 1.8;
  }

  .terms-content :global(a) {
    color: var(--primary-color);
    word-break: break-word;
  }
</style>
