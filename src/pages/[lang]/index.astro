---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import RealityCheck from '../../components/RealityCheck.astro';
import UseCases from '../../components/UseCases.astro';
import Features from '../../components/Features.astro';
import Screenshots from '../../components/Screenshots.astro';
import Pricing from '../../components/Pricing.astro';
import MiniFaq from '../../components/MiniFaq.astro';
import Motivation from '../../components/Motivation.astro';
import Newsletter from '../../components/Newsletter.astro';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---

<Layout title="Freeshard - Deine souveräne Cloud-Plattform" lang={lang}>
  <Hero lang={lang} />
  <RealityCheck lang={lang} />
  <UseCases lang={lang} />
  <Features lang={lang} />
  <Screenshots lang={lang} />
  <Pricing lang={lang} />
  <MiniFaq lang={lang} />
  <Motivation lang={lang} />
  <Newsletter lang={lang} />
</Layout>
