---
import { de } from '../i18n/de';
import { en } from '../i18n/en';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const content = lang === 'en' ? en : de;
const t = content.useCases;
const useCasesList = Object.values(t.items);

// Wir müssen die Icons hier manuell mappen, da sie nicht in den Übersetzungsdateien stehen sollten (technische Pfade)
const icons = {
  photos: { simple: "🖼️", tech: "/icons/apps/immich-logo.svg", software: "Immich", url: "https://immich.app/" },
  documents: { simple: "📄", tech: "/icons/apps/paperless-ngx.svg", software: "Paperless-ngx", url: "https://docs.paperless-ngx.com/" },
  passwords: { simple: "🔑", tech: "/icons/apps/vaultwarden.svg", software: "Vaultwarden", url: "https://github.com/dani-garcia/vaultwarden" },
  recipes: { simple: "🍲", tech: "/icons/apps/kitchenowl.png", software: "KitchenOwl", url: "https://app.kitchenowl.org/" },
  finances: { simple: "💶", tech: "/icons/apps/actual.png", software: "Actual", url: "https://actualbudget.org/" },
  notes: { simple: "📝", tech: "/icons/apps/memos.webp", software: "Memos", url: "https://usememos.com" },
  audiobooks: { simple: "🎧", tech: "/icons/apps/audiobookshelf.png", software: "Audiobookshelf", url: "https://www.audiobookshelf.org/" },
  files: { simple: "📂", tech: "/icons/apps/filebrowser.svg", software: "Filebrowser", url: "https://filebrowser.org/" },
  more: { simple: "✨", tech: "/icons/apps/opensource.svg", software: "Open Source", url: null }
};

// Wir mappen die übersetzten Texte auf die Icons
const itemsWithIcons = Object.keys(t.items).map(key => {
  const item = t.items[key as keyof typeof t.items];
  const iconData = icons[key as keyof typeof icons];
  return { ...item, ...iconData };
});
---

<section id="use-cases">
  <div class="container">
    <h2>{t.sectionTitle}</h2>
    <p class="section-description">{t.sectionDescription}</p>
    
    <div class="tech-toggle-wrapper">
      <label class="switch">
        <input type="checkbox" id="tech-toggle">
        <span class="switch-slider"></span>
      </label>
      <span class="toggle-label">{t.toggleLabel}</span>
    </div>
    
    <div class="use-cases-grid" id="use-cases-grid">
      {itemsWithIcons.map(useCase => (
        <div class="use-case-card">
          <div class="card-header">
            <div class="icon-container">
              <div class="simple-icon">{useCase.simple}</div>
              <div class="tech-icon">
                <img src={useCase.tech} alt={useCase.software} loading="lazy" />
              </div>
            </div>
            {useCase.software && (
              useCase.url ? (
                <a href={useCase.url} target="_blank" rel="noopener noreferrer" class="software-badge software-link">
                  {useCase.software}
                </a>
              ) : (
                <div class="software-badge">{useCase.software}</div>
              )
            )}
          </div>
          <h3>{useCase.title}</h3>
          <div class="description-container">
            <p class="simple-text">{useCase.simpleDescription}</p>
            <p class="tech-text">{useCase.techDescription}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="disclaimer-box" id="tech-disclaimer">
      <p>{t.disclaimer}</p>
    </div>
  </div>
</section>

<script>
  const techToggle = document.getElementById('tech-toggle');
  const grid = document.getElementById('use-cases-grid');
  const disclaimer = document.getElementById('tech-disclaimer');

  techToggle?.addEventListener('change', () => {
    const isTech = (techToggle as HTMLInputElement).checked;
    
    if (isTech) {
      grid?.classList.add('show-tech');
      disclaimer?.classList.add('visible');
    } else {
      grid?.classList.remove('show-tech');
      disclaimer?.classList.remove('visible');
    }
  });
</script>

<style>
  .tech-toggle-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 3rem;
  }

  .toggle-label {
    margin-left: 1rem;
    font-weight: 600;
    color: var(--text-color);
    cursor: pointer;
  }

  .use-cases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .use-case-card {
    background-color: var(--bg-color);
    padding: 2rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    text-align: left;
    position: relative;
    overflow: hidden;
  }

  .use-case-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    border-color: var(--primary-color);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    height: 64px;
  }

  .icon-container {
    position: relative;
    width: 64px;
    height: 64px;
  }

  .simple-icon, .tech-icon {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .simple-icon {
    font-size: 3.5rem;
    opacity: 1;
    transform: scale(1);
  }

  .tech-icon {
    opacity: 0;
    transform: scale(0.5) rotate(-10deg);
  }
  
  .tech-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 12px;
  }

  .software-badge {
    background-color: var(--bg-light);
    color: var(--text-light);
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid var(--border-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-left: auto;
    opacity: 0;
    transform: translateX(20px);
    transition: all 0.4s ease;
  }

  .software-link {
    display: inline-block;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .software-link:hover {
    background-color: var(--primary-color);
    color: white;
    border-color: var(--primary-color);
    transform: translateX(0) scale(1.05);
  }

  .use-case-card h3 {
    color: var(--primary-color);
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }

  .description-container {
    position: relative;
  }

  .simple-text, .tech-text {
    color: var(--text-light);
    line-height: 1.6;
    font-size: 0.95rem;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .simple-text {
    opacity: 1;
    transform: translateY(0);
    position: relative;
  }

  .tech-text {
    opacity: 0;
    transform: translateY(10px);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    pointer-events: none;
  }

  /* Tech-Mode Styles */
  .use-cases-grid.show-tech .simple-icon {
    opacity: 0;
    transform: scale(0.5) rotate(10deg);
  }

  .use-cases-grid.show-tech .tech-icon {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  .use-cases-grid.show-tech .software-badge {
    opacity: 1;
    transform: translateX(0);
  }

  .use-cases-grid.show-tech .simple-text {
    opacity: 0;
    transform: translateY(-10px);
    pointer-events: none;
  }

  .use-cases-grid.show-tech .tech-text {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    position: relative;
  }
  
  .use-cases-grid.show-tech .simple-text {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
  }

  .disclaimer-box {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    border-top: 1px solid var(--border-color);
    max-height: 0;
    opacity: 0;
    padding-top: 0;
    margin-top: 0;
    overflow: hidden;
    transition: all 0.5s ease;
  }

  .disclaimer-box.visible {
    max-height: 200px;
    opacity: 1;
    padding-top: 2rem;
    margin-top: 2rem;
  }

  .disclaimer-box p {
    font-size: 0.8rem;
    color: var(--text-light);
    opacity: 0.8;
    line-height: 1.5;
  }

  /* Switch Styles */
  .switch { position: relative; display: inline-block; width: 50px; height: 28px; flex-shrink: 0; }
  .switch input { opacity: 0; width: 0; height: 0; }
  .switch-slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #ccc; transition: .4s; border-radius: 34px; }
  .switch-slider:before { position: absolute; content: ""; height: 20px; width: 20px; left: 4px; bottom: 4px; background-color: white; transition: .4s; border-radius: 50%; }
  input:checked + .switch-slider { background-color: var(--primary-color); }
  input:focus + .switch-slider { box-shadow: 0 0 1px var(--primary-color); }
  input:checked + .switch-slider:before { transform: translateX(22px); }
</style>
