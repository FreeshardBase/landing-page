---
import { SHARD_MARK } from '../lib/branding';
---

<template id="shard-id-badge-tpl">
  <style>
    :host { display: inline-flex; align-items: center; gap: 0.75rem;
            padding: 0.625rem 1.25rem; border: 1px solid var(--border-color, #e5e7eb);
            border-radius: 0.5rem; font-family: ui-monospace, monospace;
            background: var(--bg-light, #f9fafb); }
    img { height: var(--shard-badge-size, 1.5rem); width: auto; }
    span { font-size: 1.25rem; letter-spacing: 0.1em; font-weight: 600; }
  </style>
  <img alt="Shard" />
  <span></span>
</template>

<script is:inline define:vars={{ mark: SHARD_MARK }}>
  if (!customElements.get('shard-id-badge')) {
    class ShardIdBadge extends HTMLElement {
      static get observedAttributes() { return ['shard-id']; }
      connectedCallback() {
        const tpl = document.getElementById('shard-id-badge-tpl');
        const root = this.attachShadow({ mode: 'open' });
        root.appendChild(tpl.content.cloneNode(true));
        root.querySelector('img').src = mark;
        this.render();
      }
      attributeChangedCallback() { this.render(); }
      render() {
        if (!this.shadowRoot) return;
        const span = this.shadowRoot.querySelector('span');
        if (span) span.textContent = this.getAttribute('shard-id') || '';
      }
    }
    customElements.define('shard-id-badge', ShardIdBadge);
  }
</script>
