---
import {
  BRAND_LOGO_DARK,
  BRAND_LOGO_DARK_2X,
  BRAND_LOGO_DARK_4X
} from "../lib/branding";

const content = {
  de: {
    titleLine1: "Dein Shard.",
    titleLine2: "Deine Daten. Deine Freiheit.",
    description: "Ein Shard ist dein ganz persönliches, privates Stück einer souveränen Cloud. Hier gehören deine Daten nur dir – sicher gehostet in Europa und befreit von der Neugier großer Konzerne. Wir kümmern uns um die Technik, damit du deine Freiheit einfach genießen kannst.",
    cta: {
      primary: "Jetzt loslegen",
      secondary: "Mehr erfahren"
    }
  }
};

const t = content.de;
---

<section id="hero" class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-brand" aria-label="Freeshard">
        <img
          class="hero-logo"
          src={BRAND_LOGO_DARK}
          srcset={`${BRAND_LOGO_DARK_2X} 2x, ${BRAND_LOGO_DARK_4X} 4x`}
          width="220"
          height="44"
          alt="Freeshard"
          loading="eager"
          decoding="async"
        />
      </div>
      <h1>
        <span class="highlight">{t.titleLine1}</span><br />
        {t.titleLine2}
      </h1>
      <p class="hero-description">{t.description}</p>
      <div class="hero-cta">
        <a href="#pricing" class="btn btn-primary">{t.cta.primary}</a>
        <a href="#features" class="btn btn-secondary">
          {t.cta.secondary}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 8rem 0 6rem; /* Etwas mehr Platz oben */
    text-align: center;
  }

  .hero-brand {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .hero-logo {
    display: block;
    height: auto;
    max-width: 240px;
    width: 100%;
  }

  .hero-content h1 {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }
  
  .hero-content h1 .highlight {
    color: #a3bffa; /* Ein helles Blau/Lila für den Akzent */
    font-size: 4rem; /* "Dein Shard" etwas größer */
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .hero-description {
    font-size: 1.25rem;
    margin-bottom: 2.5rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    opacity: 0.95;
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex; /* Flexbox für Zentrierung von Icon + Text */
    align-items: center;
    justify-content: center;
    gap: 0.5rem; /* Abstand zwischen Icon und Text */
    padding: 0.875rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.5rem;
    transition: all 0.3s;
  }

  .btn-primary {
    background-color: white;
    color: #667eea;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
  }

  .btn-secondary {
    background-color: transparent;
    color: white;
    border: 2px solid white;
  }

  .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  /* Optional: Icon etwas anpassen */
  .btn-icon {
    font-size: 1.2rem; /* Icon etwas größer als der Text */
  }

  @media (max-width: 768px) {
    .hero {
      padding: 5rem 0 4rem;
    }

    .hero-logo {
      max-width: 200px;
    }

    .hero-content h1 {
      font-size: 2.5rem;
    }
    
    .hero-content h1 .highlight {
      font-size: 3rem;
    }

    .hero-description {
      font-size: 1.125rem;
    }
  }
</style>
