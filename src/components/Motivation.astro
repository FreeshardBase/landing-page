---
import { de } from '../i18n/de';
import { en } from '../i18n/en';
import Modal from './Modal.astro';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const content = lang === 'en' ? en : de;
const t = content.motivation;
const valuesList = Object.values(t.values);

// Der `BASE_URL` wird automatisch aus der `astro.config.mjs` gelesen.
const BASE_URL = import.meta.env.BASE_URL;
---

<section id="motivation">
  <div class="container">
    <h2>{t.sectionTitle}</h2>
    <p class="section-description">{t.sectionDescription}</p>
    <div class="motivation-content">
      <div class="motivation-text">
        <h3>{t.story.title}</h3>
        {t.story.paragraphs.map(p => <p set:html={p} />)}
      </div>
      <div class="motivation-stats">
        {valuesList.map(item => (
          <>
            <button class="stat-card" data-modal-trigger={item.link}>
              <div class="stat-number">{item.value}</div>
              <div class="stat-label">{item.label}</div>
            </button>
            <Modal id={item.link} title={item.title} content={item.explanation} />
          </>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .motivation-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .motivation-text h3 {
    color: var(--primary-color);
    margin-bottom: 1.5rem;
  }

  .motivation-text p {
    margin-bottom: 1.5rem;
    color: var(--text-light);
    font-size: 1.125rem;
    line-height: 1.8;
  }
  
  .motivation-text p :global(a) {
    color: var(--primary-color);
    text-decoration: underline;
    font-weight: 500;
  }
  
  .motivation-text p :global(a:hover) {
    text-decoration: none;
  }

  .motivation-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .stat-card {
    background-color: var(--bg-color);
    padding: 2rem;
    border-radius: 0.75rem;
    text-align: center;
    border: 1px solid var(--border-color);
    transition: all 0.3s;
    text-decoration: none;
    display: block;
    position: relative;
    cursor: pointer;
    font-family: inherit;
  }

  .stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    border-color: var(--primary-color);
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
  }

  .stat-label {
    color: var(--text-light);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .motivation-content {
      grid-template-columns: 1fr;
    }

    .motivation-stats {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('[data-modal-trigger]');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const modalId = trigger.getAttribute('data-modal-trigger');
        const modal = document.querySelector(`[data-modal-id="${modalId}"]`);
        if (modal) {
          modal.classList.add('active');
        }
      });
    });
  });
</script>
