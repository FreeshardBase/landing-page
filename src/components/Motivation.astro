---
import { BASE_URL } from "../lib/branding";

// --- Internationalisierungs-Setup (i18n) ---
const content = {
  de: {
    sectionTitle: "Unsere Mission",
    sectionDescription: "Deine digitale Freiheit, unsere Leidenschaft.",
    story: {
      title: "Warum es uns gibt",
      paragraphs: [
        "Wir waren frustriert von der Abhängigkeit großer Tech-Konzerne. Wir glauben, dass jeder das Recht auf eine eigene, unabhängige digitale Präsenz haben sollte – ohne technische Hürden und ohne die eigenen Daten zu opfern.",
        "Deshalb haben wir eine Lösung geschaffen, die von Grund auf einfach, transparent und fair ist. Bei uns gibt es keine versteckten Kosten und keine Datenkraken. Unser Code ist <a href='" + BASE_URL + "/faq'>Fair Source</a> – das bedeutet maximale Transparenz für dich.",
        "Und das Beste: Echte Unabhängigkeit heißt für uns, dass du jederzeit gehen kannst. Du kannst deinen kompletten Shard mitnehmen und ihn selbst hosten, wenn du das möchtest. Deine Daten und dein System gehören dir."
      ]
    },
    // Wir nutzen die Kacheln nun für unsere Kernwerte statt für Statistiken
    values: {
      location: { value: "EU", label: "Server-Standort", link: "/faq#data-location" },
      code: { value: "Fair", label: "Fair Source Code", link: "/faq#fair-source" },
      data: { value: "Deins", label: "Voller Daten-Export", link: "/faq#export" },
      privacy: { value: "Privat", label: "Kein Tracking", link: "/faq#privacy" }
    }
  }
};

const t = content.de;
const valuesList = Object.values(t.values);
---

<section id="motivation">
  <div class="container">
    <h2>{t.sectionTitle}</h2>
    <p class="section-description">{t.sectionDescription}</p>
    <div class="motivation-content">
      <div class="motivation-text">
        <h3>{t.story.title}</h3>
        {t.story.paragraphs.map(p => <p set:html={p} />)}
      </div>
      <div class="motivation-stats">
        {valuesList.map(item => (
          <a href={`${BASE_URL}${item.link}`} class="stat-card">
            <div class="stat-number">{item.value}</div>
            <div class="stat-label">{item.label}</div>
            <div class="info-icon">ℹ️</div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .motivation-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .motivation-text h3 {
    color: var(--primary-color);
    margin-bottom: 1.5rem;
  }

  .motivation-text p {
    margin-bottom: 1.5rem;
    color: var(--text-light);
    font-size: 1.125rem;
    line-height: 1.8;
  }
  
  .motivation-text p :global(a) {
    color: var(--primary-color);
    text-decoration: underline;
    font-weight: 500;
  }
  
  .motivation-text p :global(a:hover) {
    text-decoration: none;
  }

  .motivation-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .stat-card {
    background-color: var(--bg-color);
    padding: 2rem;
    border-radius: 0.75rem;
    text-align: center;
    border: 1px solid var(--border-color);
    transition: all 0.3s;
    text-decoration: none; /* Link-Unterstreichung entfernen */
    display: block;
    position: relative;
  }

  .stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    border-color: var(--primary-color);
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
  }

  .stat-label {
    color: var(--text-light);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .info-icon {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    font-size: 0.8rem;
    opacity: 0.5;
  }
  
  .stat-card:hover .info-icon {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .motivation-content {
      grid-template-columns: 1fr;
    }

    .motivation-stats {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
