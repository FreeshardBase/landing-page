---
import { de } from '../i18n/de';
import { en } from '../i18n/en';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const content = lang === 'en' ? en : de;
const t = content.miniFaq;
---

<section id="mini-faq" class="mini-faq">
  <div class="container">
    <h2>{t.title}</h2>
    <p class="section-description">{t.description}</p>
    <div class="mini-faq-grid">
      {t.items.map(item => (
        <div class="mini-faq-card">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </div>
      ))}
    </div>
    <div class="mini-faq-link">
      <a href={`/${lang}/faq`} class="btn btn-secondary">{t.linkText}</a>
    </div>
  </div>
</section>

<style>
  .mini-faq {
    padding: 4rem 0;
  }

  .mini-faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .mini-faq-card {
    background-color: var(--bg-color);
    padding: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
  }

  .mini-faq-card h3 {
    color: var(--primary-color);
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }

  .mini-faq-card p {
    color: var(--text-light);
    line-height: 1.6;
  }

  .mini-faq-link {
    text-align: center;
    margin-top: 2rem;
  }
</style>
