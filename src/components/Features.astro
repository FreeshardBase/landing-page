---
// --- Internationalisierungs-Setup (i18n) ---
const content = {
  de: {
    sectionTitle: "Deine Vorteile",
    sectionDescription: "Warum Freeshard die richtige Wahl für dein digitales Zuhause ist.",
    features: {
      independence: { 
        icon: "🦅", 
        title: "Endlich unabhängig", 
        description: "Mach dich frei von Google, Apple und Co. Deine Daten gehören allein dir und werden nicht für Werbung analysiert oder verkauft." 
      },
      managed: { 
        icon: "🛠️", 
        title: "Kein Technik-Stress", 
        description: "Updates, Backups und Sicherheit? Darum kümmern wir uns im Hintergrund. Du genießt einfach deine Anwendungen." 
      },
      privacy: { 
        icon: "🇪🇺", 
        title: "Sicher in Europa", 
        description: "Deine Daten liegen sicher auf Servern in der EU. Deine Daten sind vor dem Zugriff durch US-Behörden (US Cloud Act) geschützt." 
      },
      central: { 
        icon: "🏠", 
        title: "Alles an einem Ort", 
        description: "Fotos, Dokumente, Passwörter – verwalte dein ganzes digitales Leben zentral, übersichtlich und unter deiner Kontrolle." 
      },
      fair: { 
        icon: "🤝", 
        title: "Fair & Transparent", 
        description: "Keine versteckten Kosten, keine langen Verträge. Du zahlst nur, was du wirklich nutzt und kannst monatlich kündigen." 
      },
      support: { 
        icon: "💬", 
        title: "Persönliche Hilfe", 
        description: "Bei Fragen sind wir für dich da. Unser Team aus echten Experten hilft dir persönlich und kompetent weiter."
      }
    }
  }
};

const t = content.de;
const featuresList = Object.values(t.features);
---

<section id="features">
  <div class="container">
    <h2>{t.sectionTitle}</h2>
    <p class="section-description">{t.sectionDescription}</p>
    <div class="features-grid">
      {featuresList.map(feature => (
        <div class="feature-card">
          <div class="feature-icon">{feature.icon}</div>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    background-color: var(--bg-color);
    padding: 2rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
    transition: all 0.3s;
  }

  .feature-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .feature-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    color: var(--primary-color);
    margin-bottom: 0.75rem;
  }

  .feature-card p {
    color: var(--text-light);
    line-height: 1.7;
  }
</style>
