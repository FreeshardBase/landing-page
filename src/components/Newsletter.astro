---
import { de } from '../i18n/de';
import { en } from '../i18n/en';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const content = lang === 'en' ? en : de;
const t = content.newsletter;
---

<section id="newsletter">
  <div class="container">
    <h2>{t.sectionTitle}</h2>
    <p class="section-description">{t.sectionDescription}</p>
    <div class="newsletter-form-container">
      <form id="newsletter-form" class="newsletter-form">
        <input
          type="email"
          id="email"
          name="contact[email]"
          placeholder={t.form.placeholder}
          required
          class="email-input"
        />
        <button type="submit" class="submit-btn" id="submit-btn">{t.form.button}</button>
      </form>
      <p id="form-message" class="form-message"></p>
    </div>
  </div>
</section>

<script define:vars={{ t }}>
  const NEWSLETTER_URL = 'https://controller.freeshard.net/api/newsletter/subscribe';

  document.getElementById('newsletter-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const emailInput = document.getElementById('email');
    const submitBtn = document.getElementById('submit-btn');
    const message = document.getElementById('form-message');

    if (!emailInput || !message || !submitBtn) return;

    // Validate email
    if (!emailInput.value || !emailInput.validity.valid) {
      message.textContent = t.form.errorMessage || 'Please enter a valid email.';
      message.classList.remove('success');
      message.classList.add('error');
      return;
    }

    // Disable submit button and show loading state
    submitBtn.disabled = true;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = t.form.sendingMessage || 'Sending...';
    message.textContent = '';

    try {
      const response = await fetch(NEWSLETTER_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: emailInput.value }),
      });

      const data = await response.json();

      if (data.success) {
        message.textContent = t.form.successMessage;
        message.classList.remove('error');
        message.classList.add('success');
        emailInput.value = '';
      } else {
        message.textContent = t.form.errorMessage || 'Subscription failed. Please try again.';
        message.classList.remove('success');
        message.classList.add('error');
      }
    } catch (_) {
      message.textContent = t.form.errorMessage || 'An error occurred. Please try again.';
      message.classList.remove('success');
      message.classList.add('error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;

      // Reset message after 5 seconds
      setTimeout(() => {
        message.textContent = '';
        message.classList.remove('success', 'error');
      }, 5000);
    }
  });
</script>

<style>
  #newsletter {
    /* Wir nutzen hier den gleichen Verlauf wie im Hero für Konsistenz */
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 6rem 0; /* Mehr Padding oben/unten */
  }

  #newsletter h2 {
    color: white;
    margin-bottom: 1rem;
  }
  
  #newsletter .section-description {
    color: rgba(255, 255, 255, 0.9); /* Leicht transparentes Weiß für bessere Lesbarkeit */
    margin-bottom: 3rem;
  }

  .newsletter-form-container {
    max-width: 600px;
    margin: 0 auto;
  }

  .newsletter-form {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    background: rgba(255, 255, 255, 0.1); /* Leichter Hintergrund für den Container */
    padding: 0.5rem;
    border-radius: 0.75rem;
  }

  .email-input {
    flex: 1;
    padding: 1rem 1.5rem;
    border: 2px solid transparent;
    border-radius: 0.5rem;
    font-size: 1rem;
    outline: none;
    transition: all 0.3s;
  }

  .email-input:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.3);
  }

  .submit-btn {
    padding: 1rem 2rem;
    background-color: white;
    color: #667eea; /* Textfarbe passend zum Theme */
    border: none;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
    white-space: nowrap; /* Verhindert Umbruch des Textes */
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
    background-color: #f8fafc;
  }

  .form-message {
    text-align: center;
    font-weight: 600;
    min-height: 1.5rem;
    margin-top: 1rem;
  }

  .form-message.success {
    color: #d1fae5; /* Helles Grün für Erfolg auf dunklem Hintergrund */
  }

  .form-message.error {
    color: #fecaca; /* Helles Rot für Fehler auf dunklem Hintergrund */
  }

  .submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  @media (max-width: 768px) {
    .newsletter-form {
      flex-direction: column;
      background: transparent; /* Kein Hintergrund auf Mobile */
      padding: 0;
    }

    .submit-btn {
      width: 100%;
    }
  }
</style>
