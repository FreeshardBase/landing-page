---
// --- Internationalisierungs-Setup (i18n) ---
const content = {
  de: {
    sectionTitle: "Auf dem Laufenden bleiben",
    sectionDescription: "Erfahre als Erstes von neuen Apps für deinen Shard und erhalte wertvolle Tipps für deine digitale Unabhängigkeit. Kein Spam, nur relevante Infos.",
    form: {
      placeholder: "Deine E-Mail-Adresse",
      button: "Anmelden",
      successMessage: "Vielen Dank für deine Anmeldung! Bitte prüfe dein Postfach."
    }
  }
};

const t = content.de;
---

<section id="newsletter">
  <div class="container">
    <h2>{t.sectionTitle}</h2>
    <p class="section-description">{t.sectionDescription}</p>
    <div class="newsletter-form-container">
      <form id="newsletter-form" class="newsletter-form">
        <input 
          type="email" 
          id="email" 
          name="email" 
          placeholder={t.form.placeholder}
          required 
          class="email-input"
        />
        <button type="submit" class="submit-btn">{t.form.button}</button>
      </form>
      <p id="form-message" class="form-message"></p>
    </div>
  </div>
</section>

<script define:vars={{ t }}>
  document.getElementById('newsletter-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const emailInput = document.getElementById('email');
    const message = document.getElementById('form-message');
    
    if (emailInput && message) {
      // Simuliert eine erfolgreiche Anmeldung
      message.textContent = t.form.successMessage;
      message.classList.add('success');
      emailInput.value = '';
      
      // Nachricht nach 5 Sekunden zurücksetzen
      setTimeout(() => {
        message.textContent = '';
        message.classList.remove('success');
      }, 5000);
    }
  });
</script>

<style>
  #newsletter {
    background: var(--brand-gradient);
    color: white;
  }

  #newsletter h2,
  #newsletter .section-description {
    color: white;
  }

  .newsletter-form-container {
    max-width: 600px;
    margin: 0 auto;
  }

  .newsletter-form {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .email-input {
    flex: 1;
    padding: 1rem 1.5rem;
    border: none;
    border-radius: 0.5rem;
    font-size: 1rem;
    outline: none;
  }

  .email-input:focus {
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.3);
  }

  .submit-btn {
    padding: 1rem 2rem;
    background-color: white;
    color: #667eea;
    border: none;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  }

  .form-message {
    text-align: center;
    font-weight: 500;
    min-height: 1.5rem;
  }

  .form-message.success {
    color: #d1fae5;
  }

  @media (max-width: 768px) {
    .newsletter-form {
      flex-direction: column;
    }

    .submit-btn {
      width: 100%;
    }
  }
</style>
