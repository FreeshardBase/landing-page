---
// --- Internationalisierungs-Setup (i18n) ---
const content = {
  de: {
    sectionTitle: "Auf dem Laufenden bleiben",
    sectionDescription: "Erfahre als Erstes von neuen Apps für deinen Shard und erhalte wertvolle Tipps für deine digitale Unabhängigkeit. Kein Spam, nur relevante Infos.",
    form: {
      placeholder: "Deine E-Mail-Adresse",
      button: "Anmelden",
      successMessage: "Vielen Dank für deine Anmeldung! Bitte prüfe dein Postfach."
    }
  }
};

const t = content.de;
---

<section id="newsletter">
  <div class="container">
    <h2>{t.sectionTitle}</h2>
    <p class="section-description">{t.sectionDescription}</p>
    <div class="newsletter-form-container">
      <form id="newsletter-form" class="newsletter-form">
        <input 
          type="email" 
          id="email" 
          name="email" 
          placeholder={t.form.placeholder}
          required 
          class="email-input"
        />
        <button type="submit" class="submit-btn">{t.form.button}</button>
      </form>
      <p id="form-message" class="form-message"></p>
    </div>
  </div>
</section>

<script define:vars={{ t }}>
  document.getElementById('newsletter-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const emailInput = document.getElementById('email');
    const message = document.getElementById('form-message');
    
    if (emailInput && message) {
      // Simuliert eine erfolgreiche Anmeldung
      message.textContent = t.form.successMessage;
      message.classList.add('success');
      emailInput.value = '';
      
      // Nachricht nach 5 Sekunden zurücksetzen
      setTimeout(() => {
        message.textContent = '';
        message.classList.remove('success');
      }, 5000);
    }
  });
</script>

<style>
  #newsletter {
    /* Wir nutzen hier den gleichen Verlauf wie im Hero für Konsistenz */
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 6rem 0; /* Mehr Padding oben/unten */
  }

  #newsletter h2 {
    color: white;
    margin-bottom: 1rem;
  }
  
  #newsletter .section-description {
    color: rgba(255, 255, 255, 0.9); /* Leicht transparentes Weiß für bessere Lesbarkeit */
    margin-bottom: 3rem;
  }

  .newsletter-form-container {
    max-width: 600px;
    margin: 0 auto;
  }

  .newsletter-form {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    background: rgba(255, 255, 255, 0.1); /* Leichter Hintergrund für den Container */
    padding: 0.5rem;
    border-radius: 0.75rem;
  }

  .email-input {
    flex: 1;
    padding: 1rem 1.5rem;
    border: 2px solid transparent;
    border-radius: 0.5rem;
    font-size: 1rem;
    outline: none;
    transition: all 0.3s;
  }

  .email-input:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.3);
  }

  .submit-btn {
    padding: 1rem 2rem;
    background-color: white;
    color: #667eea; /* Textfarbe passend zum Theme */
    border: none;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
    white-space: nowrap; /* Verhindert Umbruch des Textes */
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
    background-color: #f8fafc;
  }

  .form-message {
    text-align: center;
    font-weight: 600;
    min-height: 1.5rem;
    margin-top: 1rem;
  }

  .form-message.success {
    color: #d1fae5; /* Helles Grün für Erfolg auf dunklem Hintergrund */
  }

  @media (max-width: 768px) {
    .newsletter-form {
      flex-direction: column;
      background: transparent; /* Kein Hintergrund auf Mobile */
      padding: 0;
    }

    .submit-btn {
      width: 100%;
    }
  }
</style>
